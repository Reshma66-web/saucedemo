О‚·  
О‚·             publishHTML([ 
О‚·                 allowMissing: true, 
О‚·                 alwaysLinkToLastBuild: true, 
О‚·                 keepAll: true, 
О‚·                 reportDir: 'playwright-report', 
О‚·                 reportFiles: 'index.html', 
О‚·                 reportName: 'Playwright HTML Report' 
