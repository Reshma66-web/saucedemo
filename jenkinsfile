О‚·                 
bat 'npm install' 
О‚·                 
bat 'npx playwright install' 
О‚·             
} 
О‚·         
} 
О‚·  
О‚·         
stage('Run Playwright Tests') { 
steps { 
О‚·             
О‚·                 script { 
О‚·  
О‚·                     // Execute Playwright tests 
О‚·                     def testStatus = bat( 
О‚·                         script: 'npx playwright test', 
О‚·                         returnStatus: true 
О‚·                     ) 
О‚·  
О‚·                     // Continue pipeline even if tests fail 
О‚·                     if (testStatus != 0) { 
О‚·                         echo 'Playwright tests failed, continuing to 
publish report...' 
О‚·                     } 
О‚·                 } 
О‚·             } 
О‚·         } 
О‚·     } 
О‚·  
О‚·     post { 
О‚·         always { 
О‚·  
